# ==============================================
# 数据库配置
# ==============================================

# MySQL服务器地址
DB_HOST=localhost

# MySQL端口
DB_PORT=3306

# 数据库用户名
DB_USER=root

# 数据库密码（请修改为实际密码）
DB_PASSWORD=your_password_here

# 数据库名称
DB_NAME=metro_sim

# 连接池配置（可选）
DB_CONNECTION_LIMIT=16
DB_QUEUE_LIMIT=0
DB_CONNECT_TIMEOUT_MS=10000

# ==============================================
# 服务器配置
# ==============================================

# HTTP服务器端口
PORT=3000

# 服务器监听地址（0.0.0.0表示监听所有网络接口）
HOST=0.0.0.0

# API版本
API_VERSION=1.0

# 运行环境（development / production）
NODE_ENV=development

# ==============================================
# CORS配置
# ==============================================

# 是否启用CORS（1启用，0禁用）
CORS_ENABLED=1

# CORS允许的源（* 表示允许所有源）
CORS_ORIGIN=*

# ==============================================
# Socket.IO配置
# ==============================================

# Socket.IO tick间隔（毫秒）
# 值越小推送越频繁，但占用资源越多
SOCKET_TICK_MS=1000

# ==============================================
# 外部服务集成配置（模拟后端 / 模拟大模型）
# ==============================================

# 仿真后端服务地址（例如 http://127.0.0.1:3200）
# 为空表示关闭中台到仿真后端的主动调用
SIM_ENGINE_BASE_URL=

# 仿真后端触发路径
SIM_ENGINE_PATH=/mock/backend/run

# 大模型服务地址（例如 http://127.0.0.1:3300）
# 为空表示关闭中台到大模型服务的主动调用
LLM_BASE_URL=

# 大模型方案生成路径
LLM_PLAN_PATH=/mock/llm/plan

# 外部HTTP调用超时（毫秒）
EXTERNAL_HTTP_TIMEOUT_MS=15000

# 帧写入端点令牌（可选，建议在联调后开启）
# 影响：POST /api/simulations/:simId/frames
FRAME_INGEST_TOKEN=

# 集成触发端点令牌（可选，建议在联调后开启）
# 影响：POST /api/integration/backend/start 和 POST /api/integration/llm/plan
INTEGRATION_API_TOKEN=

# ==============================================
# 幂等性配置
# ==============================================

# 幂等性缓存TTL（毫秒）
IDEMPOTENCY_TTL_MS=600000

# ==============================================
# 调试配置
# ==============================================

# 是否启用调试模式（true / false）
DEBUG=true

# ==============================================
# 安全配置（可选）
# ==============================================

# 是否启用认证（1启用，0禁用）
# AUTH_ENABLED=0

# 认证密钥
# AUTH_SECRET=your_secret_key_here
